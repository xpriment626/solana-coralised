# ============================================================================
# Solana AAT Library — Shared Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is sourced by every agent's startup.sh before launch.
# Only set the variables you need — agents that don't use a given key
# will simply ignore it.
# ============================================================================

# ── LLM Provider ────────────────────────────────────────────────────────────
# Used by all agents (also declared in coral-agent.toml [options])
OPENAI_API_KEY=

# ── Solana Core ─────────────────────────────────────────────────────────────
# RPC endpoint — required by nearly every agent that touches the chain.
# If using Helius: https://mainnet.helius-rpc.com/?api-key=<your-helius-key>
# Default public endpoint is rate-limited; use a provider for production.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet private key (base58-encoded) — required by agents that sign/submit
# transactions (DeFi swaps, token launches, NFT mints, etc.)
# NEVER commit this value. Keep it in .env only.
SOLANA_PRIVATE_KEY=

# ── Infrastructure Providers ────────────────────────────────────────────────
# Helius — used by: solana-helius, solana-helius-dflow, solana-helius-phantom
# The raw API key (not the full RPC URL). Helius agents use this for REST
# endpoints (DAS API, webhooks, priority fees, etc.) separate from RPC.
# Get a key at https://dashboard.helius.dev
HELIUS_API_KEY=

# QuickNode — used by: solana-quicknode
QUICKNODE_ENDPOINT=

# Carbium — used by: solana-carbium
CARBIUM_API_KEY=

# ── DeFi Protocols ──────────────────────────────────────────────────────────
# Jupiter — used by: solana-jupiter-swap, solana-meteora (Zap SDK)
# Get a key at https://portal.jup.ag
JUPITER_API_KEY=

# ── Data & Analytics ────────────────────────────────────────────────────────
# CoinGecko — used by: solana-coingecko
# API type: "demo" (free, 30 calls/min) or "pro" (paid, up to 1000 calls/min)
COINGECKO_API_KEY=
COINGECKO_API_TYPE=demo

# ── Social / Intelligence ──────────────────────────────────────────────────
# Twitter/X API — used by: solana-ct-alpha
# Requires at least the Basic tier ($100/mo) for search endpoints.
# Free tier is write-only and won't work for alpha research.
# Get access at https://developer.x.com
TWITTER_BEARER_TOKEN=
